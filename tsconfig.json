{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    "outDir": "dist/assets",
    "declaration": false,
    "sourceMap": false,
    "noEmitOnError": true
  },
  "include": ["src"]
}
